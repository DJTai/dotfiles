!! main colors
*background:    #1d1f21
*foreground:    #c5c8c6
*cursorColor:   #c5c8c6

!! black dark/light
*color0:    #282a2e
*color8:    #373b41

!! red dark/light
*color1:    #a54242
*color9:    #cc6666

!! green dark/light
*color2:    #8c9440
*color10:   #b5bd68

!! yellow dark/light
*color3:    #de935f
*color11:   #f0c674

!! blue dark/light
*color4:    #5f819d
*color12:   #81a2be

!! magenta dark/light
*color5:    #85678f
*color13:   #b294bb

!! cyan dark/light
*color6:    #5e8d87
*color14:   #8abeb7

!! white dark/light
*color7:    #707880
*color15:   #e8e8e8

URxvt.font:                     xft:Source Code Pro:size=10.5
URxvt.depth:                    32
URxvt*scrollBar:                false
URxvt*mouseWheelScrollPage:     false
URxvt*cursorBlink:              true
URxvt*saveLines:                5000
URxvt*internalBorder:           5
URxvt*geometry:                 70x19

! 'fake' transparency w/o Compton
URxvt*inheritPixmap:            true
URxvt*transparent:              true
URxvt*shading:                  20

rofi.color-enabled: true
!!                 backgr.  border   sep.
rofi.color-window: #282a2e, #b5bd68, #b5bd68
!!                 bg-1     fnt-clr  bg-2     sel-bg   sel-clr
rofi.color-normal: #282a2e, #c5c8c6, #282a2e, #c5c8c6, #595f29
rofi.color-active: #282a2e, #c5c8c6, #8c9440, #c5c8c6, #78824B
rofi.color-urgent: #282a2e, #c5c8c6, #8c9440, #c5c8c6, #78824B

rofi.separator-style: solid
rofi.sidebar-mode: false
rofi.lines: 5
rofi.font: Source Code Pro Semibold 10.5
rofi.bw: 1
rofi.columns: 2
rofi.padding: 5
rofi.fixed-num-lines: true
rofi.hide-scrollbar: true
